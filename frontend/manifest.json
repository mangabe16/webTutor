{
  "manifest_version": 3,
  "name": "Web Tutor — Voice Input",
  "version": "2.0",
  "description": "Right-click any page element for an instant explanation, or hover and press ` to ask by voice and hear the reply.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
