{
  "manifest_version": 3,
  "name": "Web Tutor — Voice Input",
  "version": "2.0",
  "description": "Hover over any element, press Alt+Shift+V, ask a question, and hear the answer.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
